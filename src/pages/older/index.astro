---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('older'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => a.data.title.localeCompare(b.data.title));
---

<BaseLayout title="Older Writings | Christopher Audretsch">
  <div class="max-w-3xl mx-auto px-6 py-8 md:py-16">
    <h1 class="font-serif text-3xl md:text-4xl font-semibold text-text mb-3 md:mb-4">Older Writings</h1>
    <p class="text-text/60 mb-8 md:mb-10">
      Essays from an earlier blog, circa 2020.
    </p>

    {posts.length === 0 ? (
      <p class="text-text/60">No posts yet. Check back soon!</p>
    ) : (
      <div class="space-y-10">
        {posts.map((post) => (
          <PostCard
            title={post.data.title}
            href={`/older/${post.slug}`}
            description={post.data.description}
          />
        ))}
      </div>
    )}
  </div>
</BaseLayout>
