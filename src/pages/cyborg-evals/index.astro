---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('cyborg-evals'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.posted.valueOf() - a.data.posted.valueOf());
---

<BaseLayout title="Cyborg Evals | Christopher Audretsch">
  <div class="max-w-3xl mx-auto px-6 py-8 md:py-16">
    <h1 class="font-serif text-3xl md:text-4xl font-semibold text-text mb-3 md:mb-4">Cyborg Evals / Benchmarks</h1>
    <p class="text-text/60 mb-8 md:mb-10">
      On measuring AI capability when humans and models are already entangled.
    </p>

    {posts.length === 0 ? (
      <p class="text-text/60">No posts yet. Check back soon!</p>
    ) : (
      <div class="space-y-10">
        {posts.map((post) => (
          <PostCard
            title={post.data.title}
            href={post.data.externalUrl ?? `/cyborg-evals/${post.slug}`}
            external={!!post.data.externalUrl}
            date={post.data.posted}
            description={post.data.description}
            tags={post.data.tags}
          />
        ))}
      </div>
    )}
  </div>
</BaseLayout>
