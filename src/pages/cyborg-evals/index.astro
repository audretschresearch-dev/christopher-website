---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArchiveList from '../../components/ArchiveList.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('cyborg-evals'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.posted.valueOf() - a.data.posted.valueOf());
---

<BaseLayout title="Cyborg Evals | Christopher Audretsch">
  <div class="max-w-reading mx-auto px-5 sm:px-6 py-10 md:py-14">
    <h1 class="font-serif font-semibold text-text text-[2.4rem] tracking-[-0.045em] mb-2">Cyborg Evals / Benchmarks</h1>
    <p class="post-meta text-muted text-[1.05rem] mb-8">
      On measuring AI capability when humans and models are already entangled.
    </p>

    {posts.length === 0 ? (
      <p class="text-muted">No posts yet. Check back soon!</p>
    ) : (
      <ArchiveList base="/cyborg-evals" posts={posts} />
    )}
  </div>
</BaseLayout>
