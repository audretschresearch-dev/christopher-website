---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import { getCollection } from 'astro:content';

const toWrite = (await getCollection('reading-writing-list'))
  .filter((p) => !p.data.draft && p.data.listSection === 'write')
  .sort((a, b) => b.data.posted.valueOf() - a.data.posted.valueOf());
---

<BaseLayout title="Writing List | Christopher Audretsch">
  <div class="max-w-3xl mx-auto px-6 py-8 md:py-16">
    <h1 class="font-serif text-3xl md:text-4xl font-semibold text-text mb-3 md:mb-4">Writing List</h1>
    <p class="text-text/60 mb-8 md:mb-10">
      Things I want to write about.
    </p>

    {toWrite.length === 0 ? (
      <p class="text-text/60">Nothing here yet.</p>
    ) : (
      <div class="space-y-10">
        {toWrite.map((post) => (
          <PostCard
            title={post.data.title}
            href={post.data.externalUrl ?? `/reading-writing-list/${post.slug}`}
            external={!!post.data.externalUrl}
            date={post.data.posted}
            description={post.data.description}
            tags={post.data.tags}
          />
        ))}
      </div>
    )}
  </div>
</BaseLayout>
