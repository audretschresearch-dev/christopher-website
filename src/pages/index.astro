---
import BaseLayout from '../layouts/BaseLayout.astro';
import ShelfSection from '../components/ShelfSection.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.posted.valueOf() - a.data.posted.valueOf())
  .slice(0, 5);

// Philosophy: show these three, in this order, on the homepage.
const philosophyFeatured = [
  'consilience-why-i-think-we-live-in-a-simulation',
  'epstein-and-my-world-model',
  'claudes-constitution-is-an-excellent-guide-for-humans-too',
];
const allPhilosophy = (await getCollection('philosophy')).filter((p) => !p.data.draft);
const philosophyPosts = philosophyFeatured
  .map((slug) => allPhilosophy.find((p) => p.slug === slug))
  .filter(Boolean);

// AI: show only these two on the homepage.
const aiFeatured = [
  'toward-a-superphilosopher-ai',
  'disagreeing-with-janus-and-funding-philosophers',
];
const allAi = (await getCollection('ai')).filter((p) => !p.data.draft);
const aiPosts = aiFeatured
  .map((slug) => allAi.find((p) => p.slug === slug))
  .filter(Boolean);

const memeticsPosts = (await getCollection('memetics'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => {
    const ap = a.data.part, bp = b.data.part;
    if (ap != null && bp != null) return ap - bp;
    if (ap != null) return -1;
    if (bp != null) return 1;
    return b.data.posted.valueOf() - a.data.posted.valueOf();
  })
  .slice(0, 5);

const cyborgPosts = (await getCollection('cyborg-evals'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.posted.valueOf() - a.data.posted.valueOf())
  .slice(0, 5);
---

<BaseLayout title="Christopher Audretsch">
  <div class="max-w-home mx-auto px-5 sm:px-6 py-8 md:py-14">
    <!-- Hero / frontispiece -->
    <section class="mb-14 pb-10 border-b border-rule">
      <img
        src="/always-has-been.jpg"
        alt="Always has been meme"
        class="w-full max-w-[360px] rounded-md mb-6"
      />
      <h1 class="font-serif font-semibold text-text leading-[0.95] tracking-[-0.055em] text-[clamp(2.2rem,6vw,4.25rem)] mb-3">
        Christopher Audretsch
      </h1>
      <p class="text-muted text-xl">
        I'm curious.
      </p>
      <a
        href="/about"
        class="post-meta inline-block mt-4 text-accent hover:underline underline-offset-[3px]"
      >
        More about me &rarr;
      </a>
    </section>

    {philosophyPosts.length > 0 && (
      <ShelfSection heading="Philosophy" base="/philosophy" posts={philosophyPosts} />
    )}
    {aiPosts.length > 0 && (
      <ShelfSection heading="AI" base="/ai" posts={aiPosts} />
    )}
    {memeticsPosts.length > 0 && (
      <ShelfSection heading="Memetics" base="/memetics" posts={memeticsPosts} />
    )}
    {cyborgPosts.length > 0 && (
      <ShelfSection heading="Cyborg Evals" base="/cyborg-evals" posts={cyborgPosts} />
    )}
    {posts.length > 0 && (
      <ShelfSection heading="Recent Writing" base="/blog" posts={posts} viewAllLabel="View all posts" />
    )}
  </div>
</BaseLayout>
