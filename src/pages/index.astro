---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import { getCollection } from 'astro:content';

const all = (await getCollection('posts')).filter((p) => !p.data.draft);
const bySlug = (slug) => all.find((p) => p.slug === slug);

// Curated "shelves" — explicit featured slugs keep ordering intentional.
const philosophyFeatured = [
  'ai-identity',
  'consilience-why-i-think-we-live-in-a-simulation',
  'epstein-and-my-world-model',
  'claudes-constitution-is-an-excellent-guide-for-humans-too',
];
const philosophyPosts = philosophyFeatured.map(bySlug).filter(Boolean);

const aiFeatured = [
  'toward-a-superphilosopher-ai',
  'disagreeing-with-janus-and-funding-philosophers',
];
const aiPosts = aiFeatured.map(bySlug).filter(Boolean);

const memeticsPosts = all
  .filter((p) => p.data.tags?.includes('memetics'))
  .sort((a, b) => {
    const ap = a.data.part, bp = b.data.part;
    if (ap != null && bp != null) return ap - bp;
    if (ap != null) return -1;
    if (bp != null) return 1;
    return b.data.posted.valueOf() - a.data.posted.valueOf();
  })
  .slice(0, 5);

const cyborgPosts = all
  .filter((p) => p.data.tags?.includes('cyborg-evals'))
  .sort((a, b) => b.data.posted.valueOf() - a.data.posted.valueOf())
  .slice(0, 5);

const recentPosts = all
  .filter((p) => p.data.listSection !== 'write')
  .sort((a, b) => b.data.posted.valueOf() - a.data.posted.valueOf())
  .slice(0, 5);
---

<BaseLayout title="Christopher Audretsch">
  <div class="max-w-3xl mx-auto px-6 py-8 md:py-16">
    <section class="mb-10 md:mb-16">
      <img
        src="/always-has-been.jpg"
        alt="Always has been meme"
        class="w-full rounded-lg mb-6 md:mb-8"
      />
      <h1 class="font-serif text-3xl md:text-4xl font-semibold text-text mb-4 md:mb-6">
        Christopher Audretsch
      </h1>
      <p class="text-lg text-text/80 leading-relaxed">
        I'm curious.
      </p>
      <a
        href="/about"
        class="inline-block mt-4 text-accent hover:underline"
      >
        More about me &rarr;
      </a>
    </section>

    {philosophyPosts.length > 0 && (
      <section class="mb-10 md:mb-16">
        <h2 class="font-serif text-xl md:text-2xl font-semibold text-text mb-6 md:mb-8 tracking-[0.35em]">Philosophy</h2>
        <div class="space-y-8">
          {philosophyPosts.map((post) => (
            <PostCard
              title={post.data.title}
              href={`/writing/${post.slug}`}
              date={post.data.posted}
              description={post.data.description}
              tags={post.data.tags}
            />
          ))}
        </div>
        <a href="/tags/philosophy" class="inline-block mt-10 text-accent hover:underline">View all &rarr;</a>
      </section>
    )}

    {aiPosts.length > 0 && (
      <section class="mb-10 md:mb-16">
        <h2 class="font-serif text-xl md:text-2xl font-semibold text-text mb-6 md:mb-8">AI</h2>
        <div class="space-y-8">
          {aiPosts.map((post) => (
            <PostCard
              title={post.data.title}
              href={`/writing/${post.slug}`}
              date={post.data.posted}
              description={post.data.description}
              tags={post.data.tags}
            />
          ))}
        </div>
        <a href="/tags/ai" class="inline-block mt-10 text-accent hover:underline">View all &rarr;</a>
      </section>
    )}

    {memeticsPosts.length > 0 && (
      <section class="mb-10 md:mb-16">
        <h2 class="font-serif text-xl md:text-2xl font-semibold text-text mb-6 md:mb-8">Memetics</h2>
        <div class="space-y-8">
          {memeticsPosts.map((post) => (
            <PostCard
              title={post.data.title}
              href={`/writing/${post.slug}`}
              date={post.data.posted}
              description={post.data.description}
              tags={post.data.tags}
            />
          ))}
        </div>
        <a href="/tags/memetics" class="inline-block mt-10 text-accent hover:underline">View all &rarr;</a>
      </section>
    )}

    {cyborgPosts.length > 0 && (
      <section class="mb-10 md:mb-16">
        <h2 class="font-serif text-xl md:text-2xl font-semibold text-text mb-6 md:mb-8">Cyborg Evals</h2>
        <div class="space-y-8">
          {cyborgPosts.map((post) => (
            <PostCard
              title={post.data.title}
              href={`/writing/${post.slug}`}
              date={post.data.posted}
              description={post.data.description}
              tags={post.data.tags}
            />
          ))}
        </div>
        <a href="/tags/cyborg-evals" class="inline-block mt-10 text-accent hover:underline">View all &rarr;</a>
      </section>
    )}

    <section>
      <h2 class="font-serif text-xl md:text-2xl font-semibold text-text mb-6 md:mb-8">Recent Writing</h2>
      <div class="space-y-8">
        {recentPosts.map((post) => (
          <PostCard
            title={post.data.title}
            href={post.data.externalUrl ?? `/writing/${post.slug}`}
            external={!!post.data.externalUrl}
            date={post.data.posted}
            description={post.data.description}
            tags={post.data.tags}
          />
        ))}
      </div>
      <a href="/writing" class="inline-block mt-10 text-accent hover:underline">View all posts &rarr;</a>
    </section>
  </div>
</BaseLayout>
