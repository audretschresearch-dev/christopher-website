---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.posted.valueOf() - a.data.posted.valueOf())
  .slice(0, 5);

const memeticsPosts = (await getCollection('memetics'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => {
    const ap = a.data.part, bp = b.data.part;
    if (ap != null && bp != null) return ap - bp;
    if (ap != null) return -1;
    if (bp != null) return 1;
    return b.data.posted.valueOf() - a.data.posted.valueOf();
  })
  .slice(0, 5);

const philosophyPosts = (await getCollection('philosophy'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.posted.valueOf() - a.data.posted.valueOf())
  .slice(0, 5);

const cyborgPosts = (await getCollection('cyborg-evals'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.posted.valueOf() - a.data.posted.valueOf())
  .slice(0, 5);
---

<BaseLayout title="Christopher Audretsch">
  <div class="max-w-3xl mx-auto px-6 py-8 md:py-16">
    <section class="mb-10 md:mb-16">
      <img
        src="/always-has-been.jpg"
        alt="Always has been meme"
        class="w-full rounded-lg mb-6 md:mb-8"
      />
      <h1 class="font-serif text-3xl md:text-4xl font-semibold text-text mb-4 md:mb-6">
        Christopher Audretsch
      </h1>
      <p class="text-lg text-text/80 leading-relaxed">
        I'm curious.
      </p>
      <a
        href="/about"
        class="inline-block mt-4 text-accent hover:underline"
      >
        More about me &rarr;
      </a>
    </section>

    <section class="mb-10 md:mb-16">
      <h2 class="font-serif text-xl md:text-2xl font-semibold text-text mb-6 md:mb-8">Memetics</h2>
      <div class="space-y-8">
        {memeticsPosts.map((post) => (
          <PostCard
            title={post.data.title}
            href={`/memetics/${post.slug}`}
            date={post.data.posted}
            description={post.data.description}
          />
        ))}
      </div>
      <a
        href="/memetics"
        class="inline-block mt-10 text-accent hover:underline"
      >
        View all &rarr;
      </a>
    </section>

    {philosophyPosts.length > 0 && (
      <section class="mb-10 md:mb-16">
        <h2 class="font-serif text-xl md:text-2xl font-semibold text-text mb-6 md:mb-8 tracking-[0.35em]">Philosophy</h2>
        <div class="space-y-8">
          {philosophyPosts.map((post) => (
            <PostCard
              title={post.data.title}
              href={`/philosophy/${post.slug}`}
              date={post.data.posted}
              description={post.data.description}
            />
          ))}
        </div>
        <a
          href="/philosophy"
          class="inline-block mt-10 text-accent hover:underline"
        >
          View all &rarr;
        </a>
      </section>
    )}

    {cyborgPosts.length > 0 && (
      <section class="mb-10 md:mb-16">
        <h2 class="font-serif text-xl md:text-2xl font-semibold text-text mb-6 md:mb-8">Cyborg Evals</h2>
        <div class="space-y-8">
          {cyborgPosts.map((post) => (
            <PostCard
              title={post.data.title}
              href={`/cyborg-evals/${post.slug}`}
              date={post.data.posted}
              description={post.data.description}
              tags={post.data.tags}
            />
          ))}
        </div>
        <a
          href="/cyborg-evals"
          class="inline-block mt-10 text-accent hover:underline"
        >
          View all &rarr;
        </a>
      </section>
    )}

    <section>
      <h2 class="font-serif text-xl md:text-2xl font-semibold text-text mb-6 md:mb-8">Recent Writing</h2>
      <div class="space-y-8">
        {posts.map((post) => (
          <PostCard
            title={post.data.title}
            href={`/blog/${post.slug}`}
            date={post.data.posted}
            description={post.data.description}
            tags={post.data.tags}
          />
        ))}
      </div>
      {posts.length > 0 && (
        <a
          href="/blog"
          class="inline-block mt-10 text-accent hover:underline"
        >
          View all posts &rarr;
        </a>
      )}
    </section>
  </div>
</BaseLayout>
