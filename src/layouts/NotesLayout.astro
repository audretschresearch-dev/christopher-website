---
interface Props {
  title: string;
  source: string;
  created?: Date;
  modified?: Date;
}

const { title, source, created, modified } = Astro.props;

const displayDate = modified || created;
const formattedDate = displayDate
  ? displayDate.toLocaleDateString('en-US', {
      year: 'numeric',
      month: 'long',
      day: 'numeric',
    })
  : null;
---

<article class="max-w-article mx-auto px-5 sm:px-6 py-10 md:py-14">
  <header class="mb-10">
    <div class="flex items-center gap-3 mb-4">
      <span class="post-meta text-xs font-medium uppercase tracking-wider text-accent bg-accent-soft px-2 py-1 rounded">
        {source}
      </span>
    </div>
    <h1 class="font-serif font-semibold text-text text-[2rem] sm:text-4xl leading-[1.05] tracking-[-0.04em] mb-2">
      {title}
    </h1>
    {formattedDate && (
      <time class="post-meta text-muted text-sm" datetime={displayDate?.toISOString()}>
        {formattedDate}
      </time>
    )}
  </header>
  <div class="prose prose-lg max-w-none">
    <slot />
  </div>
</article>
