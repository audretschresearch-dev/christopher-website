---
interface Props {
  title: string;
  source: string;
  created?: Date;
  modified?: Date;
}

const { title, source, created, modified } = Astro.props;

const displayDate = modified || created;
const formattedDate = displayDate
  ? displayDate.toLocaleDateString('en-US', {
      year: 'numeric',
      month: 'long',
      day: 'numeric',
    })
  : null;
---

<article class="max-w-3xl mx-auto px-6 py-12">
  <header class="mb-10">
    <div class="flex items-center gap-3 mb-4">
      <span class="text-xs font-medium uppercase tracking-wider text-accent bg-accent/10 px-2 py-1 rounded">
        {source}
      </span>
    </div>
    <h1 class="font-serif text-3xl font-semibold text-text leading-tight mb-2">
      {title}
    </h1>
    {formattedDate && (
      <time class="text-text/50 text-sm" datetime={displayDate?.toISOString()}>
        {formattedDate}
      </time>
    )}
  </header>
  <div class="prose prose-lg max-w-none">
    <slot />
  </div>
</article>
