---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  posted: Date;
  description?: string;
}

const { title, posted, description } = Astro.props;

const formattedDate = posted.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout title={title} description={description}>
  <article class="max-w-article mx-auto px-5 sm:px-6 py-10 md:py-14">
    <header class="mb-8 md:mb-10">
      <h1 class="font-serif font-semibold text-text leading-[1.03] tracking-[-0.045em] text-[2rem] sm:text-4xl md:text-[3.25rem] mb-2">
        {title}
      </h1>
      <time class="post-meta block text-muted text-sm mt-3" datetime={posted.toISOString()}>
        {formattedDate}
      </time>
    </header>
    <div class="prose prose-lg max-w-none">
      <slot />
    </div>
  </article>
</BaseLayout>
