---
const year = new Date().getFullYear();

const socials = [
  { href: 'https://www.lesswrong.com/users/eye-you', label: 'LessWrong' },
  { href: 'https://x.com/eye_you_x', label: 'X' },
];
---

<footer class="border-t border-gray-200 mt-auto">
  <div class="max-w-3xl mx-auto px-6 py-8 flex flex-col sm:flex-row items-center justify-between gap-3">
    <p class="text-sm text-text/50">
      &copy; {year} Christopher Audretsch
    </p>
    <div class="flex items-center gap-5">
      {socials.map((s) => (
        <a
          href={s.href}
          target="_blank"
          rel="noopener noreferrer"
          class="text-sm font-medium text-text/60 hover:text-accent transition-colors"
        >
          {s.label}
        </a>
      ))}
    </div>
  </div>
</footer>
