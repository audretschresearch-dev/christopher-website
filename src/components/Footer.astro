---
const year = new Date().getFullYear();

const socials = [
  { href: 'https://www.lesswrong.com/users/eye-you', label: 'LessWrong' },
  { href: 'https://x.com/eye_you_x', label: 'X' },
];
---

<footer class="site-footer max-w-home mx-auto mt-12 px-5 sm:px-6 py-8 border-t border-rule text-[0.88rem] text-muted">
  <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-3">
    <p>&copy; {year} Christopher Audretsch</p>
    <div class="flex items-center gap-5">
      {socials.map((s) => (
        <a
          href={s.href}
          target="_blank"
          rel="noopener noreferrer"
          class="text-muted hover:text-text transition-colors"
        >
          {s.label}
        </a>
      ))}
    </div>
  </div>
</footer>
