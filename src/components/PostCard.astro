---
interface Props {
  title: string;
  href: string;
  date?: Date;
  description?: string;
}

const { title, href, date, description } = Astro.props;

const formattedDate = date
  ? date.toLocaleDateString('en-US', {
      year: 'numeric',
      month: 'long',
      day: 'numeric',
    })
  : null;
---

<article class="group">
  <a href={href} class="block">
    <h3 class="font-serif text-xl font-medium text-text group-hover:text-accent transition-colors">
      {title}
    </h3>
    {formattedDate && (
      <time class="text-sm text-text/50 mt-1 block" datetime={date?.toISOString()}>
        {formattedDate}
      </time>
    )}
    {description && (
      <p class="text-text/70 mt-2 line-clamp-2">{description}</p>
    )}
  </a>
</article>
