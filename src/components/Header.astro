---
const currentPath = Astro.url.pathname;

const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/blog', label: 'Miscellaneous' },
  { href: '/memetics', label: 'Memetics' },
  { href: '/philosophy', label: 'Philosophy' },
  { href: '/cyborg-evals', label: 'Cyborg Evals' },
  { href: '/ai', label: 'AI' },
  { href: '/trip-reports', label: 'Trip Reports' },
  { href: '/reading-writing-list', label: 'Writing List' },
  { href: '/older', label: 'Older' },
  { href: '/waluigi', label: 'waluigi' },
  { href: '/about', label: 'About' },
];

const isActive = (href: string) =>
  href === '/' ? currentPath === '/' : currentPath.startsWith(href);
---

<header class="site-header max-w-home mx-auto px-5 sm:px-6 pt-6 pb-1">
  <div class="flex flex-wrap items-baseline justify-between gap-x-6 gap-y-2">
    <a href="/" class="font-serif text-lg font-semibold text-text hover:text-accent transition-colors no-underline">
      Christopher Audretsch
    </a>
    <nav class="site-nav text-[0.92rem]">
      <ul class="flex flex-wrap items-baseline gap-x-4 gap-y-1.5">
        {navLinks.map((link) => (
          <li>
            <a
              href={link.href}
              aria-current={isActive(link.href) ? 'page' : undefined}
              class:list={[
                'no-underline transition-colors',
                isActive(link.href)
                  ? 'text-text underline underline-offset-[3px]'
                  : 'text-muted hover:text-text hover:underline underline-offset-[3px]',
              ]}
            >
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  </div>
</header>
