---
const currentPath = Astro.url.pathname;

const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/blog', label: 'Miscellaneous Writing' },
  { href: '/memetics', label: 'Memetics' },
  { href: '/philosophy', label: 'Philosophy' },
  { href: '/older', label: 'Older Writings' },
  { href: '/about', label: 'About' },
];
---

<header class="bg-header-bg border-b border-gray-200">
  <div class="max-w-3xl mx-auto px-6 py-4 md:py-6">
    <nav class="flex items-center justify-between">
      <a href="/" class="font-serif text-xl md:text-2xl font-semibold text-text hover:text-accent transition-colors">
        Christopher
      </a>

      <!-- Desktop nav -->
      <ul class="hidden md:flex gap-6 lg:gap-8">
        {navLinks.map((link) => (
          <li>
            <a
              href={link.href}
              class:list={[
                'text-sm font-medium transition-colors',
                currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href))
                  ? 'text-accent'
                  : 'text-text/70 hover:text-text',
              ]}
            >
              {link.label}
            </a>
          </li>
        ))}
      </ul>

      <!-- Mobile menu button -->
      <button
        id="menu-toggle"
        class="md:hidden p-2 -mr-2 text-text/70 hover:text-text"
        aria-label="Toggle menu"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path id="menu-icon" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </nav>

    <!-- Mobile nav -->
    <div id="mobile-menu" class="hidden md:hidden mt-4 pb-2">
      <ul class="flex flex-col gap-3">
        {navLinks.map((link) => (
          <li>
            <a
              href={link.href}
              class:list={[
                'block text-base font-medium transition-colors py-1',
                currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href))
                  ? 'text-accent'
                  : 'text-text/70 hover:text-text',
              ]}
            >
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    </div>
  </div>
</header>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  const icon = document.getElementById('menu-icon');

  toggle?.addEventListener('click', () => {
    const isOpen = !menu?.classList.contains('hidden');
    menu?.classList.toggle('hidden');

    // Toggle icon between hamburger and X
    if (isOpen) {
      icon?.setAttribute('d', 'M4 6h16M4 12h16M4 18h16');
    } else {
      icon?.setAttribute('d', 'M6 18L18 6M6 6l12 12');
    }
  });
</script>
