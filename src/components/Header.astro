---
const currentPath = Astro.url.pathname;

const writingLinks = [
  { href: '/blog', label: 'Miscellaneous Writing' },
  { href: '/memetics', label: 'Memetics' },
  { href: '/philosophy', label: 'Philosophy' },
  { href: '/cyborg-evals', label: 'Cyborg Evals' },
  { href: '/ai', label: 'AI' },
  { href: '/trip-reports', label: 'Event Trip Reports' },
  { href: '/reading-writing-list', label: 'Writing List' },
  { href: '/older', label: 'Older Writings' },
];

const isWritingActive = writingLinks.some(
  (link) => currentPath === link.href || currentPath.startsWith(link.href)
);

const linkClass = (href: string) =>
  currentPath === href || (href !== '/' && currentPath.startsWith(href))
    ? 'text-accent'
    : 'text-text/70 hover:text-text';
---

<header class="bg-header-bg border-b border-gray-200">
  <div class="max-w-3xl mx-auto px-6 py-4 md:py-6">
    <nav class="flex items-center justify-between">
      <a href="/" class="font-serif text-xl md:text-2xl font-semibold text-text hover:text-accent transition-colors">
        Christopher
      </a>

      <!-- Desktop nav -->
      <ul class="hidden md:flex items-center gap-6 lg:gap-8">
        <li>
          <a href="/" class:list={['text-sm font-medium transition-colors', linkClass('/')]}>Home</a>
        </li>

        <!-- Writing dropdown -->
        <li class="relative group">
          <button
            class:list={[
              'text-sm font-medium transition-colors flex items-center gap-1',
              isWritingActive ? 'text-accent' : 'text-text/70 hover:text-text',
            ]}
            aria-haspopup="true"
          >
            Writing
            <svg class="w-3 h-3 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </button>
          <!-- bridge + menu: visible on hover/focus-within -->
          <div class="absolute right-0 top-full pt-3 w-56 invisible opacity-0 group-hover:visible group-hover:opacity-100 group-focus-within:visible group-focus-within:opacity-100 transition-opacity z-20">
            <ul class="bg-background border border-gray-200 rounded-lg shadow-lg py-2">
              {writingLinks.map((link) => (
                <li>
                  <a
                    href={link.href}
                    class:list={[
                      'block px-4 py-2 text-sm font-medium transition-colors',
                      linkClass(link.href),
                    ]}
                  >
                    {link.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        </li>

        <li>
          <a href="/waluigi" class:list={['text-sm font-medium transition-colors', linkClass('/waluigi')]}>Waluigi</a>
        </li>

        <li>
          <a href="/about" class:list={['text-sm font-medium transition-colors', linkClass('/about')]}>About</a>
        </li>
      </ul>

      <!-- Mobile menu button -->
      <button
        id="menu-toggle"
        class="md:hidden p-2 -mr-2 text-text/70 hover:text-text"
        aria-label="Toggle menu"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path id="menu-icon" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </nav>

    <!-- Mobile nav -->
    <div id="mobile-menu" class="hidden md:hidden mt-4 pb-2">
      <ul class="flex flex-col gap-3">
        <li>
          <a href="/" class:list={['block text-base font-medium transition-colors py-1', linkClass('/')]}>Home</a>
        </li>
        <li class="pt-1">
          <span class="block text-xs font-semibold uppercase tracking-wide text-text/40 py-1">Writing</span>
          <ul class="flex flex-col gap-2 pl-3 border-l-2 border-gray-200 mt-1">
            {writingLinks.map((link) => (
              <li>
                <a
                  href={link.href}
                  class:list={['block text-base font-medium transition-colors py-1', linkClass(link.href)]}
                >
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </li>
        <li class="pt-1">
          <a href="/waluigi" class:list={['block text-base font-medium transition-colors py-1', linkClass('/waluigi')]}>Waluigi</a>
        </li>
        <li class="pt-1">
          <a href="/about" class:list={['block text-base font-medium transition-colors py-1', linkClass('/about')]}>About</a>
        </li>
      </ul>
    </div>
  </div>
</header>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  const icon = document.getElementById('menu-icon');

  toggle?.addEventListener('click', () => {
    const isOpen = !menu?.classList.contains('hidden');
    menu?.classList.toggle('hidden');

    // Toggle icon between hamburger and X
    if (isOpen) {
      icon?.setAttribute('d', 'M4 6h16M4 12h16M4 18h16');
    } else {
      icon?.setAttribute('d', 'M6 18L18 6M6 6l12 12');
    }
  });
</script>
