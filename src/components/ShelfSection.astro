---
import TagList from './TagList.astro';

interface Post {
  data: { title: string; posted?: Date; description?: string; tags?: string[] };
  slug: string;
}

interface Props {
  heading: string;
  base: string;        // e.g. "/philosophy"
  posts: Post[];
  viewAllLabel?: string;
}

const { heading, base, posts, viewAllLabel = 'View all' } = Astro.props;

const fmt = (d?: Date) =>
  d ? d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }) : null;
---

<section class="mt-11 pt-5 border-t border-rule first:mt-0 first:pt-0 first:border-t-0">
  <h2 class="site-nav text-sm font-semibold uppercase tracking-[0.04em] text-accent mb-4">
    {heading}
  </h2>
  <div class="grid gap-3">
    {posts.map((post) => (
      <a
        href={`${base}/${post.slug}`}
        class="group block no-underline"
      >
        <span class="font-serif text-lg text-text group-hover:text-accent group-hover:underline underline-offset-[3px] transition-colors">
          {post.data.title}
        </span>
        <span class="post-meta flex flex-wrap items-center gap-x-3 gap-y-1 mt-0.5">
          {fmt(post.data.posted) && (
            <span class="text-muted text-[0.88rem] tabular-nums">{fmt(post.data.posted)}</span>
          )}
          {post.data.tags && post.data.tags.length > 0 && <TagList tags={post.data.tags} />}
        </span>
      </a>
    ))}
  </div>
  <a href={base} class="post-meta inline-block mt-5 text-sm text-accent hover:underline underline-offset-[3px]">
    {viewAllLabel} &rarr;
  </a>
</section>
