---
import { isMeta, tagLabel } from '../lib/tags';

interface Props {
  tag: string;
}

const { tag } = Astro.props;

const meta = isMeta(tag);
const label = tagLabel(tag);

// Topic tags link to their tag page; HQ is a non-clickable accent badge.
const pillClass = meta
  ? 'bg-accent/10 text-accent'
  : 'bg-header-bg text-text/70 hover:bg-accent/10 hover:text-accent';
const base = 'inline-block text-xs px-2.5 py-0.5 rounded-full font-medium transition-colors';
---

{meta ? (
  <span class={`${base} ${pillClass}`}>{label}</span>
) : (
  <a href={`/tags/${tag}`} class={`${base} ${pillClass} no-underline`}>{label}</a>
)}
