---
import TagPill from './TagPill.astro';
import { isTopic } from '../lib/tags';

interface Props {
  tags?: string[];
  class?: string;
}

const { tags, class: cls = '' } = Astro.props;

// Show topic tags (clickable) + HQ (badge). Hide LQ/personal/private publicly.
const visible = (tags ?? []).filter((t) => isTopic(t) || t === 'HQ');
---

{visible.length > 0 && (
  <div class={`flex flex-wrap gap-1.5 ${cls}`}>
    {visible.map((t) => <TagPill tag={t} />)}
  </div>
)}
